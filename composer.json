{
    "name": "yiisoft/yii-bulma",
    "type": "library",
    "description": "Collection of Widgets for Bulma CSS framework.",
    "keywords": [
        "yii",
        "bulma",
        "widget"
    ],
    "homepage": "https://www.yiiframework.com/",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yiisoft/yii-bulma/issues?state=open",
        "forum": "https://www.yiiframework.com/forum/",
        "wiki": "https://www.yiiframework.com/wiki/",
        "irc": "ircs://irc.libera.chat:6697/yii",
        "chat": "https://t.me/yii3en",
        "source": "https://github.com/yiisoft/yii-bulma"
    },
    "require": {
        "php": "^8.0",
        "yiisoft/arrays": "^2.0|^3.0",
        "yiisoft/assets": "^4.0.0 || ^5.0.0",
        "yiisoft/files": "^2.0",
        "yiisoft/html": "^2.5.0 || ^3.0",
        "yiisoft/widget": "^2.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.9.1",
        "friendsofphp/php-cs-fixer": "^3.95.13",
        "phpunit/phpunit": "^9.5",
        "rector/rector": "^2.5.7",
        "roave/infection-static-analysis-plugin": "^1.16",
        "spatie/phpunit-watcher": "^1.23",
        "vimeo/psalm": "^4.30 || ^5.26.1 || ^6.16.1",
        "yiisoft/code-style": "^1.0",
        "yiisoft/test-support": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Yiisoft\\Yii\\Bulma\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yiisoft\\Yii\\Bulma\\Tests\\": "tests"
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "target-directory": "tools",
            "forward-command": true
        },
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "infection/extension-installer": true,
            "composer/package-versions-deprecated": true,
            "composer/installers": true,
            "oomphinc/composer-installers-extender": true
        }
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "psalm": "psalm",
        "rector": "rector",
        "test": "phpunit --testdox --no-interaction",
        "test-watch": "phpunit-watcher watch"
    }
}
